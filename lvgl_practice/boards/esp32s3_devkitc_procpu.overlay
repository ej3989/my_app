#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/led/led.h>
#include <zephyr/dt-bindings/display/panel.h>
#include <zephyr/dt-bindings/mipi_dbi/mipi_dbi.h>

/ {
    aliases {
        app-buttons = &app_buttons;
        led-strip = &led_strip;
        display = &lcd0;
        touch = &touch0;
    };

    chosen {
        zephyr,display = &lcd0;
        zephyr,touch = &touch0;
    };

    app_buttons: buttons_ej {
        compatible = "gpio-keys";
        debounce-interval-ms = <50>;

        key0: key_0 {
            gpios = <&gpio0 4 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
            label = "Key0";
            zephyr,code = <INPUT_KEY_1>;
        };
        key1: key_1 {
            gpios = <&gpio0 5 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
            label = "Key1";
            zephyr,code = <INPUT_KEY_2>;
        };
        key2: key_2 {
            gpios = <&gpio0 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
            label = "Key2";
            zephyr,code = <INPUT_KEY_3>;
        };
        key3: key_3 {
            gpios = <&gpio0 15 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
            label = "Key3";
            zephyr,code = <INPUT_KEY_4>;
        };
    };

    /*
     * MHS-3.5inch RPi Display LCD-only wiring, ESP32-S3 side:
     *   LCD_RS  -> GPIO9
     *   LCD_CS  -> GPIO10
     *   LCD_SI  -> GPIO11
     *   LCD_SCK -> GPIO12
     *   RST     -> GPIO8
     *
     * Touch wiring on the same SPI bus:
     *   TP_SI / T_DIN       -> GPIO11
     *   TP_SCK / T_CLK/SCL  -> GPIO12
     *   TP_DO / T_DO / SDO  -> GPIO13
     *   TP_CS               -> GPIO16
     *   TP_IRQ              -> GPIO17
     */
    lcd_dbi: mipi_dbi {
        compatible = "zephyr,mipi-dbi-spi";
        spi-dev = <&spi2>;
        dc-gpios = <&gpio0 9 GPIO_ACTIVE_HIGH>;
        reset-gpios = <&gpio0 8 GPIO_ACTIVE_LOW>;
        xfr-min-bits = "MIPI_DBI_SPI_XFR_16BIT";
        write-only;

        #address-cells = <1>;
        #size-cells = <0>;
        status = "okay";

        lcd0: ili9488@0 {
            compatible = "ilitek,ili9488";
            reg = <0>;
            status = "okay";

            mipi-mode = "MIPI_DBI_MODE_SPI_4WIRE";
            /*
             * The LCDWiki page lists ILI9486, 320x480 resolution, XPT2046
             * touch, and SPI input up to 125MHz. Keep the first ESP32-S3
             * bring-up speed conservative; raise it only after the direct
             * display_write test is stable.
             */
            mipi-max-frequency = <40000000>;
            pixel-format = <PANEL_PIXEL_FORMAT_RGB_565>;

            /*
             * Match the Linux mhs35 overlay MADCTL value 0x28:
             * BGR + row/column exchange. In Zephyr's common ILI9XXX
             * rotation logic this is rotation 90 with MX toggled back off.
             */
            width = <320>;
            height = <480>;
            rotation = <90>;
            h-mirror;
        };
    };

    lvgl_touch {
        compatible = "zephyr,lvgl-pointer-input";
        input = <&touch0>;
        display = <&lcd0>;
        /*
         * The LVGL pointer layer rotates touch coordinates according to the
         * display orientation. Keep the XPT2046 driver in the panel's native
         * 320x480 coordinate space and let this layer apply rotation = <90>.
         */
        invert-x;
        invert-y;
        status = "okay";
    };
};

&spi2 {
    status = "okay";
    #address-cells = <1>;
    #size-cells = <0>;
    cs-gpios = <&gpio0 10 GPIO_ACTIVE_LOW>,
               <&gpio0 16 GPIO_ACTIVE_LOW>;
    pinctrl-0 = <&spim2_lcd_touch>;
    pinctrl-names = "default";

    touch0: xpt2046@1 {
        compatible = "xptek,xpt2046-waveshare-35c";
        reg = <1>;
        spi-max-frequency = <500000>;
        int-gpios = <&gpio0 17 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        touchscreen-size-x = <320>;
        touchscreen-size-y = <480>;
        min-x = <420>;
        max-x = <3710>;
        min-y = <370>;
        max-y = <3750>;
        z-threshold = <300>;
        reads = <4>;
        status = "okay";
    };
};

&pinctrl {
    spim2_lcd_touch: spim2_lcd_touch {
        group1 {
            pinmux = <SPIM2_MISO_GPIO13>,
                     <SPIM2_SCLK_GPIO12>;
        };

        group2 {
            pinmux = <SPIM2_MOSI_GPIO11>;
            output-low;
        };
    };
};

&spi3 {
    status = "disabled";
};

&i2s0_default {
    group1 {
        pinmux = <I2S0_O_SD_GPIO38>;
    };
};

&i2s0 {
    status = "okay";

    dmas = <&dma 3>;
    dma-names = "tx";

    led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-i2s";

        reg = <0>;
        chain-length = <1>;
        color-mapping = <LED_COLOR_ID_GREEN
            LED_COLOR_ID_RED
            LED_COLOR_ID_BLUE>;
        reset-delay = <500>;
    };
};

&dma {
    status = "okay";
};

&pinctrl {
    i2s1_max98357: i2s1_max98357 {
        group1 {
            pinmux = <I2S1_O_BCK_GPIO39>,
                     <I2S1_O_WS_GPIO40>,
                     <I2S1_O_SD_GPIO41>;
        };
    };
};

&i2s1 {
    status = "okay";
    pinctrl-0 = <&i2s1_max98357>;
    pinctrl-names = "default";
};

&i2c0 {
    status = "okay";

    aht10: aht10@38 {
        compatible = "aosong,aht10";
        reg =<0x38>;
        status = "okay";
    };
};