mainmenu "LVGL practice"

menu "Internet radio"

config APP_WIFI_SSID
	string "Wi-Fi SSID"
	default ""
	help
	  SSID used by the internet radio service.

config APP_WIFI_PSK
	string "Wi-Fi password"
	default ""
	help
	  WPA/WPA2 password. Leave empty only for an open network.

config APP_RADIO_HOST
	string "Internet radio host"
	default "wrti-live.streamguys1.com"

config APP_RADIO_PATH
	string "Internet radio path"
	default "/jazz-mp3"

endmenu

config LVGL_EJ_STACK_USAGE_LOG
	bool "Print LVGL EJ stack usage"
	select INIT_STACKS
	select THREAD_STACK_INFO
	select THREAD_NAME
	help
	  Enable periodic printk output for the LVGL EJ thread stack usage.
	  This is intended for debugging stack size only.

config LVGL_EJ_STACK_LOG_INTERVAL_MS
	int "LVGL EJ stack usage log interval in milliseconds"
	default 5000
	depends on LVGL_EJ_STACK_USAGE_LOG
	help
	  Interval used for periodic LVGL EJ thread stack usage output.

config APP_STACK_USAGE_LOG
	bool "Print app controller stack usage"
	select INIT_STACKS
	select THREAD_STACK_INFO
	select THREAD_NAME
	help
	  Print the app controller thread stack high-water usage.
	  This option is intended for stack size debugging.

source "Kconfig.zephyr"
